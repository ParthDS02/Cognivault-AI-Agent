# ============================================
# Cognivault AI Business Analyst Agent
# .gitignore
# ============================================

# --------------------------------------------
# Environment & Secrets
# --------------------------------------------
.env
*.env
.env.local
.env.*.local

# --------------------------------------------
# Python
# --------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# --------------------------------------------
# Virtual Environments
# --------------------------------------------
venv/
env/
ENV/
env.bak/
venv.bak/

# --------------------------------------------
# IDE & Editors
# --------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# --------------------------------------------
# Uploads & User Data
# --------------------------------------------
uploads/documents/*
uploads/datasets/*
!uploads/documents/.gitkeep
!uploads/datasets/.gitkeep

# --------------------------------------------
# Models & Embeddings
# --------------------------------------------
models/embeddings/*
!models/embeddings/.gitkeep
*.pkl
*.joblib
*.h5
*.pt
*.pth

# --------------------------------------------
# Streamlit
# --------------------------------------------
.streamlit/secrets.toml

# --------------------------------------------
# Logs & Temp Files
# --------------------------------------------
*.log
logs/
temp/
tmp/
*.tmp

# --------------------------------------------
# Data Files (Large)
# --------------------------------------------
*.csv
*.xlsx
*.xls
*.pdf
*.docx
*.pptx

# --------------------------------------------
# Audio Files
# --------------------------------------------
*.mp3
*.wav
*.ogg

# --------------------------------------------
# Jupyter Notebooks
# --------------------------------------------
.ipynb_checkpoints/
*.ipynb

# --------------------------------------------
# Testing
# --------------------------------------------
.pytest_cache/
.coverage
htmlcov/

# --------------------------------------------
# OS
# --------------------------------------------
Thumbs.db
Desktop.ini
